extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/moment.pug

block main
    .container.my-3
        .row
            .col-12
                .alert.alert-success
                | Chúc mừng bạn đã đặt hàng thành công! Mã đơn hàng của bạn là 
                b #{order.code}

        .row
            .col-12
                +box-head("Thông tin khách hàng")
                table.table.table-bordered
                    thead 
                        tr 
                            th Họ tên 
                            th Số điện thoại 
                            th Ghi chú
                            th Ngày đặt
                    tbody
                        tr
                            td #{order.fullName}
                            td #{order.phone}
                            td #{order.note}
                            td 
                                +formatDateTime(order.createdAt)
        .row
            .col-12
                +box-head("Danh sách tour")
                table.table.table-bordered
                    thead 
                        tr 
                            th Stt
                            th Ảnh
                            th tiêu đề
                            th Giá
                            th Số lượng 
                            th Tổng tiền
                    tbody
                        each item,index in orderItem
                            tr
                                td #{item.title}
                                td 
                                    img(src=item.image alt=item.slug width="80px")
                                td 
                                    a(href=`/tours/detail/${item.slug}`)  #{item.title}
                                td #{item.priceSpecial.toLocaleString()}đ
                                td #{item.quantity}
                                td #{item.total.toLocaleString()}đ
            .col-12 
                h5(class="text-right mb-4") Tổng đơn hàng: #{order.total.toLocaleString()}đ
