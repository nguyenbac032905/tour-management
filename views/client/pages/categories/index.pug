extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    .container.my-3
        .row
            .col-12
                +box-head(pageTitle)

        .row
            each item in categories
                .col-6.mb-3
                    .card
                        img.card-img-top(src=item.image)
                        .card-body
                            h5.card-title #{item.title}
                            a.btn.btn-primary(href=`/tours/${item.slug}`) Xem chi tiết