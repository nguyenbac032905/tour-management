extends ../../layouts/default.pug

block main
    h1.mb-4 #{pageTitle}

    form(action=`${prefixAdmin}/tours/create` 
        method="POST"
        enctype="multipart/form-data"
    )
        .form-group
            label(for="title") Tiêu đề
            input.form-control(
                type="text"
                id="title"
                name="title"
                required
            )

        .form-group
            label(for="category") Danh mục
            select.form-control(
                name="category_id"
                id="category"
                required
            )
                option(value="" disabled selected) Chọn danh mục
                each item in categories
                    option(value=item.id) #{item.title}
        .form-group 
            label(for="images") Chọn nhiều ảnh 
            input(
                type="file"
                class="form-control-file"
                id="images"
                name="images"
                accept="image/*"
                multiple
            )
        .form-group
            label(for="price") Giá
            input.form-control(
                type="number"
                id="price"
                name="price"
                value="0"
                min="0"
            )

        .form-group
            label(for="discount") % Giảm giá
            input.form-control(
                type="number"
                id="discount"
                name="discount"
                value="0"
                min="0"
            )

        .form-group
            label(for="stock") Số lượng
            input.form-control(
                type="number"
                id="stock"
                name="stock"
                value="0"
                min="0"
            )

        .form-group
            label(for="timeStart") Lịch khởi hành
            input.form-control(
                type="datetime-local"
                id="timeStart"
                name="timeStart"
            )

        .form-group
            label(for="position") Vị trí
            input.form-control(
                type="number"
                id="position"
                name="position"
                placeholder="Tự động tăng"
                min="1"
            )

        .form-group
            .form-check.form-check-inline
                input.form-check-input(
                    type="radio"
                    id="statusActive"
                    name="status"
                    value="active"
                    checked
                )
                label.form-check-label(for="statusActive") Hoạt động

            .form-check.form-check-inline
                input.form-check-input(
                    type="radio"
                    id="statusInActive"
                    name="status"
                    value="inactive"
                )
                label.form-check-label(for="statusInActive") Dừng hoạt động

        .form-group
            button.btn.btn-primary(type="submit") Tạo mới