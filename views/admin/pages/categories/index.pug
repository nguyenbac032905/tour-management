extends ../../layouts/default.pug
block main
    h1 Danh mục tour
    .card.mb-3
        .card-header Danh sách tour
        .card-body
            .row 
                .col-8
                .col-4
                    a.btn.btn-outline-success(href=`${prefixAdmin}/categories/create`) Thêm mới

            table(class="table table-hover table-sm")
                thead
                    tr
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Trạng thái
                        th Hành động
                tbody
                    each item,index in categories 
                        tr
                            td #{index}
                            td 
                                img(src=item.image width="100px" height="auto")
                            td #{item.title}
                            td 
                                if(item.status === "active")
                                    a(href="javascript:;" class = "badge badge-success") Hoạt động
                                else
                                    a(href="javascript:;" class = "badge badge-dange") Dừng hoạt động
                            td 
                                a.btn.btn-secondary.btn-sm(
                                    href=`/${prefixAdmin}/categories/detail/${item.id}`
                                ) Chi tiết

                                a.btn.btn-warning.btn-sm.ml-1(
                                    href=`/${prefixAdmin}/categories/edit/${item.id}`
                                ) Sửa

                                button.btn.btn-danger.btn-sm.ml-1(
                                    button-delete
                                    data-id=item.id
                                ) Xóa
                            